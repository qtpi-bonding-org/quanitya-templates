      "name": "Volume Over Time",
      "fieldId": "00000000-0000-0000-00B0-000000000002",
      "outputMode": "matrix",
      "snippetLanguage": "js",
      "snippet": "if (data.values.length === 0) return [{label: 'Volume', values: [], timestamps: []}];\nreturn [{\n  label: 'Session Volume',\n  values: data.values.map(sets => sets.reduce((sum, s) => sum + (s.Weight || 0) * (s.Reps || 0), 0)),\n  timestamps: data.timestamps\n}];",
